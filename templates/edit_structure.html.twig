{% extends 'base_setting.html.twig' %}

{% block title %} Modifier la structure du client {% endblock %}

{% block body %}
    <div class="col-dm-12">
        <div class="card">
            <div class="card-header bg-gradient-dark text-white">
                <h5 class="h5 font-weight-bolder text-uppercase">Modifier la structure du client</h5>
            </div>
            <div class="card-body">
                {{ form_start(form, {'multipart': true}) }}

                {{ form_rest(form) }}

                <div class="form-group">
                    <button class="btn btn-primary float-right">MODIFIER</button>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
    <script>
        $('.custom-file-input').on('change', function () {
            let fileName = $(this).val().split('\\').pop();
            $(this).next('.custom-file-label').addClass("selected").html(fileName);
        });
    </script>
{% endblock %}


