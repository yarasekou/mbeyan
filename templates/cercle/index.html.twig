{% extends 'base_setting.html.twig' %}

{% block title %}La liste des cercles {% endblock %}

{% block body %}
    <h5 class="font-weight-bold text-uppercase">La liste des cercles</h5>
    <hr>
    {% for message in app.flashes('success') %}
        <div class="alert alert-success text-center text-uppercase font-weight-bolder mt-3 mb-3">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger text-center text-uppercase font-weight-bolder mt-3 mb-3">
            {{ message }}
        </div>
    {% endfor %}

    <div class="table-responsiv">
        {% if cercles is not empty %}
            <table class="table text-center table-bordered table-hover font-weight-bold text-uppercase table-responsive-sm table-striped mt-3 mb-3">
                <thead>
                <tr class="bg-dark text-white">
                    <th>Nom</th>
                    <th>Latitude</th>
                    <th>Longitude</th>
                    <th>actions</th>
                </tr>
                </thead>
                <tbody>
                {% for cercle in cercles %}
                    <tr>
                        <td>{{ cercle.name }}</td>
                        <td>
                            {% if cercle.latitude == null %}
                                <span class="badge badge-danger">non défini</span>
                            {% else %}
                                <span class="badge badge-success">{{ cercle.latitude }}</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if cercle.longitude == null %}
                                <span class="badge badge-danger">non défini</span>
                            {% else %}
                                <span class="badge badge-success">{{ cercle.longitude }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group">
                                {% if app.user.isAdmin %}
                                    <a class="btn btn-sm btn-warning" href="{{ path('cercle_edit', {'id': cercle.id}) }}"><i
                                                class="fa fa-edit"></i></a>
                                    <form method="post" style="display: inline-block"
                                          action="{{ path('cercle_delete', {'id': cercle.id}) }}"
                                          onsubmit="return confirm('Êtes-vous sûr(e) de supprimer ?');">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cercle.id) }}">
                                        <button class="btn btn-sm btn-danger"><i class="fa fa-trash-alt"></i></button>
                                    </form>
                                {% else %}
                                    <button class="btn btn-sm btn-dark">AUCUNE ACTION</button>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="font-weight-bolder text-uppercase">AUCUN ENREGISTREMENT</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else%}
            <div class="alert alert-danger text-center text-uppercase font-weight-bolder">Vous n'avez pas de cercles enregistrés</div>
        {% endif %}
    </div>
    {% if app.user.isAdmin %}
        <a class="btn btn-primary font-weight-bold text-uppercase  mb-5" href="{{ path('cercle_new') }}">Nouveau cercle</a>
    {% endif %}
{% endblock %}

{% block javascripts %}
    <script>
        $(".alert").delay(5000).slideUp(200, function () {
            $(this).alert('close');
        });
    </script>
{% endblock %}
