{% extends 'base.html.twig' %}

{% block title '500 erreur donnés' %}

{% block body %}
    <div style="margin-bottom: 100px" class="container mb-5">
        <div class="card">
            <div class="card-body">
                <h3 class="font-weight-bolder text-uppercase text-center text-danger">ERROR 500, Données non valide
                    !</h3>
                <hr>
                <img src="{{ asset('images/errors/error.jpg') }}" alt="error images" width="100%" height="400px">
                <p class="text-center text-danger font-weight-bolder mt-3">L'application a rencontré des problemes de
                    données. Veuillez contactez un administrateur.</p>
            </div>
        </div>
    </div>
{% endblock %}