{% extends 'base_setting.html.twig' %}

{% block title %}La liste des types usages de bien{% endblock %}

{% block body %}
    <h5 class="font-weight-bolder text-uppercase">Les types usages de Biens</h5>
    <hr>
    {% for message in app.flashes('success') %}
        <div class="alert alert-success text-center text-uppercase font-weight-bolder mt-3">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger text-center text-uppercase font-weight-bolder mt-3">
            {{ message }}
        </div>
    {% endfor %}

    <div class="table-responsive">
        {% if type_usage_biens is not empty %}
            <table class="table table-striped table-hover table-bordered font-weight-bold text-uppercase text-center mt-3">
                <thead>
                <tr class="bg-dark text-white">
                    <th>Type</th>
                    <th>actions</th>
                </tr>
                </thead>
                <tbody>
                {% for type_usage_bien in type_usage_biens %}
                    <tr>
                        <td>{{ type_usage_bien.name }}</td>
                        <td>
                            <div class="btn-group">
                                {% if app.user.roleSuperAdminAndIsAdmin %}
                                    <a class="btn btn-sm btn-warning"
                                       href="{{ path('type_usage_bien_edit', {'id': type_usage_bien.id}) }}"><i
                                                class="fa fa-edit"></i></a>
                                    <form style="display: inline" method="post"
                                          action="{{ path('type_usage_bien_delete', {'id': type_usage_bien.id}) }}"
                                          onsubmit="return confirm('Êtes-vous sûr(e) de supprimer ?');">
                                        <input type="hidden" name="_method" value="DELETE">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('delete' ~ type_usage_bien.id) }}">
                                        <button class="btn btn-sm btn-danger"><i class="fa fa-trash-alt"></i></button>
                                    </form>
                                {% else %}
                                    <button class="btn btn-sm btn-dark disabled">AUCUNE ACTION</button>
                                {% endif %}

                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="font-weight-bolder text-uppercase">AUCUN ENREGISTREMENT</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            {% else %}
            <div class="alert alert-danger text-center font-weight-bolder text-uppercase">AUCUN ENREGISTREMENT</div>
        {% endif %}
    </div>
    {% if app.user.roleSuperAdminAndIsAdmin %}
        <a class="btn btn-primary font-weight-bolder text-uppercase mt-3 mb-3" href="{{ path('type_usage_bien_new') }}">Créer un nouveau</a>
    {% endif %}
{% endblock %}
