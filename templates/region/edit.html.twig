{% extends 'base_setting.html.twig' %}

{% block title %} Modifier la région {% endblock %}

{% block stylesheets %}

    <script type="text/javascript"
            src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCo18VhOGOgmI7qIKBjSB5kq9tJYp5HWEE&libraries=places"></script>
    <script src="https://polyfill.io/v3/polyfill.min.js?features=default"></script>
    <script
            src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCo18VhOGOgmI7qIKBjSB5kq9tJYp5HWEE&callback=initMap&libraries=&v=weekly"
            defer
    >
    </script>
{% endblock %}


{% block body %}
    <div class="card font-weight-bold text-uppercase">
        <h5 class="card-header bg-dark text-white font-weight-bold text-uppercase">
            Modifier la région</h5>
        <div class="card-body">
            <div id="map"></div>
            {{ include('region/_form.html.twig', {'button_label': 'MODIFIER'}) }}

            <a class="btn btn-primary font-weight-bold text-uppercase" href="{{ path('region_index') }}">Retourner à la
                liste</a>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        let regionForm = $('#cercle_region');
        let regionValue = regionForm.find(":selected").text();

        $(document).ready(function () {
            let val = document.getElementById('region_name').value;
            loadMap(val);
        });

        function findLocalite() {
            let val = document.getElementById('region_name').value;
            loadMap(val);
        }


        function loadMap(val) {
            $.ajax({
                url: 'https://maps.googleapis.com/maps/api/geocode/json?address=' + val + ',Mali&key=AIzaSyCo18VhOGOgmI7qIKBjSB5kq9tJYp5HWEE',
                datatype: 'json',
                type: 'get',
                success: function (data) {
                    let result = (data.results)[0];
                    let status = data.status;
                    if (status === 'OK') {
                        if (result.address_components[3].long_name === 'Mali') {
                            document.getElementById('region_latitude').value = '' + result.geometry.location.lat;
                            document.getElementById('region_longitude').value = '' + result.geometry.location.lng;
                            document.getElementById('map').style.width = '100%';
                            document.getElementById('map').style.height = '300px';
                            document.getElementById('map').classList.add('mb-5');
                            "use strict";
                            initMap(result.geometry.location.lat, result.geometry.location.lng);
                        } else {
                            alert('Impossible de trouver les coodonnées de cette région');
                            resetMap();
                        }
                    } else {
                        alert('Impossible de trouver les coodonnées de cette région');
                        resetMap();
                    }
                }
            })
        }

        function initMap(lat, lng) {
            let myLatLng = {
                lat: lat,
                lng: lng
            };
            let mapOptions = {
                zoom: 8,
                center: myLatLng,
                mapTypeId: 'hybrid',
                labels: true
            };
            new google.maps.Map(document.getElementById("map"), mapOptions);
        }

        function resetMap() {
            document.getElementById('map').style.width = '0px';
            document.getElementById('map').style.height = '0px';
            document.getElementById('map').classList.remove('mb-5');
            document.getElementById("formAdd").reset();
            "use strict";
            initMap(0, 0);
        }
    </script>
{% endblock %}
