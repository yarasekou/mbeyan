{{ form_start(form, {'attr': {'id': 'formAdd', 'onsubmit': 'return confirm("Êtes-vous sûr(e) des infos ?")'}}) }}
<div class="form-group">
    {{ form_row(form.name) }}
</div>


<div class="form-group">
    {{ form_row(form.latitude) }}
</div>

<div class="form-group">
    {{ form_row(form.longitude) }}
</div>

{{ form_widget(form) }}
<div class="btn-group float-right">
    <button type="button" id="btnFind" class="btn btn-outline-warning" onclick="findLocalite()">VERIFIER</button>
    <button class="btn btn-dark">{{ button_label|default('ENREGISTRER') }}</button>
</div>
{{ form_end(form) }}