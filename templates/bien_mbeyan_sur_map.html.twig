        function initializeSelector() {
            typeFilter.val('');
            for (let i = 1; i <= nbreBien; i++) {
                $('#list-biens #list-item' + i).remove();
            }
        }

        function transformDate(dateInit) {
            let deadLine = new Date(dateInit).getTime();
            let now = new Date().getTime();
            let t = deadLine - now;
            let days = Math.floor(t / (1000 * 60 * 60 * 24));
            let hours = Math.floor((t % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            let min = Math.floor((t % (1000 * 60 * 60)) / (1000 * 60));
            let sec = Math.floor((t % (1000 * 60)) / 1000);
            return days + ' jour ' + hours + ' h ' + min + ' min ' + sec + ' s';
        }

