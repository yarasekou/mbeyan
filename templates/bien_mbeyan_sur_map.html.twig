        $('#date_fin_dation').on('input', function () {
            document.getElementById('btn-total').classList.add('d-none');
            document.getElementById('total_montant').classList.add('d-none');
            document.getElementById('btn-export').classList.add('d-none');
            for (let i = 1; i <= nbreBien; i++) {
                $('#list-biens #list-item' + i).remove();
            }

            if (!document.getElementById('form-banque').classList.contains('d-none')) {
                let id = $('#banque').find(':selected').val();
                let valeur = $('#date_fin_dation').val();

                let val = '3';

                console.log('date == ' + valeur);

                let isValid = Date.parse(valeur);

                console.log('valid :: ' + isValid);

                if (!isNaN(isValid)) {
                    console.log('query with :: ' + valeur);
                    getBienByCritere(val, valeur, id);
                }
            }
            if (!document.getElementById('form-part').classList.contains('d-none')) {
                let id = $('#particulier').find(':selected').val();
                let valeur = $('#date_fin_dation').val();
                let val = '3';
                console.log('date == ' + valeur);
                let isValid = Date.parse(valeur);

                console.log('valid :: ' + isValid);

                if (!isNaN(isValid)) {
                    console.log('query with :: ' + valeur);
                    getBienByCritere(val, valeur, id);
