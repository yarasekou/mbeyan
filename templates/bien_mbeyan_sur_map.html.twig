        function getBienByCritere(val, value, id) {
            for (let i = 1; i <= nbreBien; i++) {
                $('#list-biens #list-item' + i).remove();
            }

            document.getElementById('btn-total').classList.add('d-none');
            document.getElementById('btn-export').classList.add('d-none');
            let critere = '';
            if (val === '1') {
                critere = 'quartier';
            }
            if (val === '2') {
                critere = 'date_prochaine_evaluation';
            }
            if (val === '3') {
                critere = 'date_fin_dation';
            }
            if (val === '4') {
                critere = 'date_sortie_immobilisation';
            }
            if (val === '5') {
                critere = 'type_document';
            }
            if (val === '6') {
                critere = 'type_acquisition';
            }

            console.log('requete :: ' + critere + ' ' + value + ' ' + id);

            $.ajax({
                url: '/koh_archivage/admin/bien-client/get_bien_client_by_critere',
                type: 'post',
                datatype: 'json',
                data: {
                    'critere': critere,
                    'valeur': value,
                    'id': id
                },
                success: function (data) {
                    initMap(data, true);
                    if (data.length !== null && data.length !== 0) {
                        document.getElementById('btn-total').classList.remove('d-none');
                        document.getElementById('btn-export').classList.remove('d-none');
                    }
                },
                error: function (error) {
                    console.log('error :: ' + JSON.stringify(error));
                }
            })
        }

