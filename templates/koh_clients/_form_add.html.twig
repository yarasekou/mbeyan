{{ form_start(form, { 'multipart': true }) }}
<div class="form-row">
    <div class="col-md-6 form-group">
        {{ form_row(form.firstName) }}
    </div>
    <div class="col-md-6 form-group">
        {{ form_row(form.lastName) }}
    </div>
</div>

<div class="form-row align-items-end">
    <div class="col-md-6 form-group">
        {{ form_row(form.email) }}
    </div>
    <div class="col-md-6 form-group">
        {{ form_row(form.nomUtilisateur) }}
    </div>
</div>

<div class="form-row align-items-end">
    <div class="col-md-6 form-group">
        {{ form_row(form.telephone) }}
    </div>
    <div class="col-md-6 form-group">
        {{ form_row(form.adresse) }}
    </div>
</div>

<div class="form-row align-items-end">
    <div class="col-md-6 form-group">
        {{ form_row(form.userProfile,  { 'attr':{ 'class': 'text-danger', 'value': 'selected' } }) }}
    </div>
    <div class="col-md-6 form-group">
        {{ form_row(form.typeCompte) }}
    </div>
</div>


<div class="form-row align-items-end" id="Struct1">

</div>

<div class="form-row align-items-end" id="Struct2">

</div>

<div class="form-row align-items-end">
    <div class="col-md-6 form-group">
        {{ form_row(form.password.first) }}
    </div>
    <div class="col-md-6 form-group pull-right">
        {{ form_row(form.password.second) }}
    </div>
</div>

{{ form_widget(form) }}

<button class="btn btn-primary float-right">{{ button_label|default('ENREGISTRER') }}</button>
{{ form_end(form) }}

<script>
    $('.custom-file-input').on('change', function () {
        let fileName = $(this).val().split('\\').pop();
        $(this).next('.custom-file-label').addClass("selected").html(fileName);
    });
</script>