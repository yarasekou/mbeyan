{% extends 'base_koh_utilisateur.html.twig' %}

{% block title %}
    Nouveau bien
{% endblock %}
{% block stylesheets %}
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCo18VhOGOgmI7qIKBjSB5kq9tJYp5HWEE&callback=initMap&libraries=&v=weekly"
            defer></script>
{% endblock %}


{% block body %}
    <div class="col-md-12">
        <div class="card">
            <h5 class="card-header font-weight-bolder text-uppercase">ENREGISTREMENT DE NOUVEAU BIEN DES CLIENTS</h5>
            <div class="card-body">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success text-center text-uppercase font-weight-bolder mt-3 mb-3">
                        {{ message }}
                    </div>
                {% endfor %}

                {% for message in app.flashes('danger') %}
                    <div class="alert alert-danger text-center text-uppercase font-weight-bolder mt-3 mb-3">
                        {{ message }}
                    </div>
                {% endfor %}
                {{ include('bien_client/_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cleave.js/1.0.2/cleave.min.js"
            integrity="sha512-SvgzybymTn9KvnNGu0HxXiGoNeOi0TTK7viiG0EGn2Qbeu/NFi3JdWrJs2JHiGA1Lph+dxiDv5F9gDlcgBzjfA=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script>

        $(document).ready(function () {
            $('#bien_client_typeCompte').val('');
            $('#bien_client_region').val('');
        });
        $('#bien_client_typeCompte').on('change', function (e) {
            let type = e.target.value;
            $('#clientKoh').empty().append($('<option>', {
                value: '',
                text: "-- Selectionner le client --"
            }));
            document.getElementById('infoClientBanque1').innerHTML = "";
            document.getElementById('infoClientBanque2').innerHTML = "";
            if (type !== '') {
                $.ajax({
                    url: '/koh_utilisateur/clients_by_type',
                    type: 'post',
                    dataType: 'json',
                    data: {
                        'type': type
                    },
                    success: function (data) {
                        console.log('data :: ' + JSON.stringify(data));
                        $('#clientKoh').empty().append($('<option>', {
                            value: '',
                            text: "-- Selectionner le client mbeyan --"
                        }));
                        $.each(data, function (index, client) {
                            $('#clientKoh').append($('<option>', {
                                value: client['id'],
                                text: client['email'].toUpperCase()
                            }));
                        });

                        // TO DO RECCUPERATION DE TYPE DE COMPTE

                        let typeId = $('#bien_client_typeCompte').val();
                        if (typeId !== '') {
                            $.ajax({
                                url: '/koh/type/compte/get/' + typeId,
                                dataType: 'json',
                                'type': 'GET',
                                success: function (data) {
                                    if (data['isStructure'] === true) {
                                        let info1 = "<div class=\"col-md-6 form-group\">\n" + "        <div class=\"form-group text-uppercase\">\n" + "            <label for=\"nom_client_banque\">Client de la structure</label>\n" + "            <input id=\"nom_client_banque\" type=\"text\" class=\"form-control text-uppercase\" name=\"nom_client_banque\" required\n" + "                   placeholder=\"nom & prénom\">\n" + "        </div>\n" + "    </div>\n" + "    <div class=\"col-md-6 form-group\">\n" + "        <div class=\"form-group\">\n" + "            <label for=\"numero_compte_client_banque\">Numero de compte client</label>\n" + "            <input id=\"numero_compte_client_banque\" type=\"text\" class=\"form-control\" name=\"numero_client_banque\"\n" + "                    placeholder=\"compte_01_12_2020 optionnel\">\n" + "        </div>\n" + "    </div>";
                                        let info2 = "<div class=\"col-md-6 form-group\">\n" + "        <div class=\"form-group text-uppercase\">\n" + "            <label for=\"contact_client_banque\">Contact du client</label>\n" + "            <input id=\"contact_client_banque\" type=\"text\" class=\"form-control text-uppercase\" name=\"contact_client_banque\" \n" + "                   placeholder=\"tél ou adresse émail\">\n" + "        </div>\n" + "    </div>\n" + "    <div class=\"col-md-6 form-group\">\n" + "        <div class=\"form-group\">\n" + "            <label for=\"adresse_compte_client_banque\">Adresse du client</label>\n" + "            <input id=\"adresse_compte_client_banque\" type=\"text\" class=\"form-control\" name=\"adresse_client_banque\"\n" + "                    placeholder=\"ville/quartier/rue\">\n" + "        </div>\n" + "    </div>";
                                        document.getElementById('infoClientBanque1').innerHTML = info1;
                                        document.getElementById('infoClientBanque2').innerHTML = info2;
                                    }
                                },
                                error: function (error) {
                                    console.log('error == ' + JSON.parse(error))
                                }
                            })
                        }
                    }
                });
            }
        });

        $('#bien_client_region').on('change', function (e) {
            $('#cercle').empty();
            if (e.target.value !== '') {
                loadCercle(+e.target.value);
            }

            function loadCercle(id) {
                $.ajax({
                    url: '/cercle/region_by_cercle/' + id,
                    type: 'get',
                    dataType: 'json',
                    success: function (data) {
                        console.log('data ' + data.length);
                        $('#cercle').empty().append($('<option>', {
                            value: '',
                            text: '-- Selectionner un cercle --'
                        }));

                        $.each(data, function (index, cercle) {
                            $('#cercle').append($('<option>', {
                                value: cercle['id'],
                                text: cercle['libelle'].toUpperCase()
                            }));
                        });
                    }
                })
            }
        });

