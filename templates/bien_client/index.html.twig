        // RECCUPERATION DES CLIENTS PAR TYPE
        function getKohClientByType(typeClient) {
            clientFilter.empty();
            $.ajax({
                url: '/koh_utilisateur/clients_by_type',
                type: 'POST',
                dataType: 'JSON',
                data: {'type': typeClient},
                success: function (data) {
                    clientFilter.append($('<option>', {
                        value: '',
                        text: '-- CHOISIR UN CLIENT --'
                    }));
                    let cpt = 0;
                    $.each(data, function (index, d) {
                        if (cpt === 0 && d.type !== undefined && d.type === 'structure') {
                            document.getElementById('formClientStructure').classList.remove('d-none');
                        } else {
                            document.getElementById('formClientStructure').classList.add('d-none');
                        }
                        clientFilter.append($('<option>', {
                            value: d['id'],
                            text: d['email']
                        }));
                    });
                    document.getElementById('formClientFilter').classList.remove('d-none');
                },
                error: function (error) {
                    console.log('error => ' + error);
                }
            })
        }

