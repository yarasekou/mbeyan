{% extends 'base_koh_utilisateur.html.twig' %}

{% block title %} La liste des biens {% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('dashboard/css/bootstrap-multiselect.css') }}" type="text/css"/>
    <script type="text/javascript" src="{{ asset('dashboard/js/bootstrap-multiselect.js') }}"></script>
{% endblock %}
{% block body %}
    <div class="container bg-white mb-5">
        <br><br>
        <h5 class="font-weight-bolder text-uppercase">Les biens des clients mbeyan</h5>
        <hr>
        <div id="alertContent" class="col-md-12">

        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success text-center text-uppercase font-weight-bolder mt-3 mb-3">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger text-center text-uppercase font-weight-bolder mt-3 mb-3">
                {{ message }}
            </div>
        {% endfor %}

        <button type="button" class="btn btn-dark float-right mb-3" data-toggle="modal"
                data-target="#exampleModalCenter">
            FILTRER LES BIENS
        </button>
        <div class="table-responsive mb-5">
            <table id="table_id" style="white-space: nowrap"
                   class="table diplay table-hover table-bordered text-center font-weight-bold text-uppercase">
                <thead>
                <tr class="bg-gradient-dark text-white">
                    <th>
                        <button id="checkAll" class="btn btn-sm btn-primary">COCHER</button>
                        <button id="inCheckAll" class="btn btn-sm btn-danger d-none">DECOCHER</button>
                    </th>
                    <th>ACTIONS</th>
                    <th><a href="#" class="text-white text-decoration-none" id="expertiseSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="expertiseASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="expertiseDESC"></i>&nbsp;EXPERTISE</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="tfSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="tfASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="tfDESC"></i>&nbsp;TF</a></th>

                    <th><a href="#" class="text-white text-decoration-none" id="numeroMbeyanSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="numeroMbeyanASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="numeroMbeyanDESC"></i>&nbsp;N°
                            MBEYAN</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="quartierSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="quartierASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger"
                                    id="quartierDESC"></i>&nbsp;QUARTIER</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="cercleSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="cercleASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger"
                                    id="cercleDESC"></i>&nbsp;CERCLE</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="regionSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="regionASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger"
                                    id="regionDESC"></i>&nbsp;REGION</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="prixSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="prixASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="prixDESC"></i>&nbsp;PRIX</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="clientSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="clientASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger"
                                    id="clientDESC"></i>&nbsp;CLIENT</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="proprietaireSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="proprietaireASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="proprietaireDESC"></i>&nbsp;PROPRIETAIRE</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="nomSurLeDocumentSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="nomSurLeDocumentASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="nomSurLeDocumentDESC"></i>&nbsp;NOM
                            SUR LE
                            DOCUMENT</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="typeAcquisitionSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="typeAcquisitionASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="typeAcquisitionDESC"></i>&nbsp;ACQUISITION</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="documentSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="documentASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger"
                                    id="documentDESC"></i>&nbsp;DOCUMENT</a></th>

                    <th><a href="#" class="text-white text-decoration-none" id="bienSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="bienASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="bienDESC"></i>&nbsp;BIEN</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="usageSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="usageASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="usageDESC"></i>&nbsp;USAGE</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="superficieSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="superficieASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="superficieDESC"></i>&nbsp;SUPERFICIE</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="lastExpertiseSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="lastExpertiseASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="lastExpertiseDESC"></i>&nbsp;DERNIERE
                            EXPERTISE</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="nextExpertiseSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="nextExpertiseASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="nextExpertiseDESC"></i>&nbsp;PROCHAINE
                            EXPERTISE</a>
                    </th>

                    <th><a href="#" class="text-white text-decoration-none" id="createdAtSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="createdAtASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="createdAtDESC"></i>&nbsp;ENREGISTRE
                            LE</a></th>

                    <th><a href="#" class="text-white text-decoration-none" id="updatedAtSort"> <i
                                    class="fa fa-sort-alpha-up d-none text-warning" id="updatedAtASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger" id="updatedAtDESC"></i>&nbsp;MODIFIER
                            LE</a></th>

                    <th><a href="#" class="text-white text-decoration-none" id="createdBySort"> <i
                                    class="fa fa-sort-alpha-up d-none  text-warning" id="createdByASC"></i> <i
                                    class="fa fa-sort-alpha-down d-none text-danger"
                                    id="createdByDESC"></i>&nbsp;PAR</a>
                    </th>
                </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
        <div class="btn-group mb-5">
            <button class="btn btn-warning mt-3 text-white" id="btnEXPORTER">EXPORTER VERS <i
                        class="fa fa-file-excel"></i>
            </button>
            <a href="{{ path('bien_client_index') }}" class="btn btn-success text-decoration-none mt-3">TOUS
                AFFICHER</a>
        </div>
    </div>
    <div class="modal fade" id="exampleModalCenter" tabindex="-1" role="dialog"
         aria-labelledby="exampleModalCenterTitle"
         aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header bg-gradient-dark text-white">
                    <h5 class="modal-title font-weight-bolder text-uppercase" id="exampleModalLongTitle">Filtre de
                        biens</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form class="col-md-12 font-weight-bolder">
                        <div class="form-row align-items-end mb-2">
                            <!-- clientFilter -->
                            <div class="col-md-6 form-group" id="formFiltreTypeClient">
                                <label for="filtreTypeClient"><u>TYPE</u></label>
                                <select id="filtreTypeClient" class="form-control text-uppercase text-center"
                                        name="typeFilter">
                                    <option value="">-- FILTRE TYPE CLIENT --</option>
                                    {% for typeCompte in typeComptes %}
                                        <option value="{{ typeCompte.id }}">-- {{ typeCompte.name|upper }} --</option>
                                    {% endfor %}
                                    <option value="">-- AUCUN --</option>
                                </select>
                            </div>
                            <div id="formClientFilter" class="col-md-6 form-group d-none">
                                <label for="clientFilter"><u>CLIENT</u></label>
                                <select name="clientFilter" class="form-control" id="clientFilter">
                                    <option value="">-- FILTER PAR CLIENT</option>
                                </select>
                            </div>
                        </div>
                        <!-- clientStructure -->
                        <div class="form-group d-none" id="formClientStructure">
                            <label for="clientStructure"><u>CLIENT STRUCTURE</u></label>
                            <input type="text" class="form-control" id="clientStructure" placeholder="nom client">
                        </div>
                        <hr>
                        <!-- filterRegion -->
                        <div class="form-row align-items-end mt-2 mb-2">
                            <div class="col-md-6 form-group">
                                <label for="filterRegion"><u>REGION</u></label>
                                <select id="filterRegion" name="region" class="form-control text-center text-uppercase">
                                    <option value="">-- CHOISIR LA REGION --</option>
                                    {% for region in regions %}
                                        <option value="{{ region.id }}">{{ region.name|upper }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <!-- filterCercle -->
                            <div class="col-md-6 form-group">
                                <label for="filterCercle"><u>CERCLE</u></label>
                                <select id="filterCercle" name="cercle" class="form-control text-center text-uppercase">
                                    <option value="">-- CHOISIR LE CERCLE --</option>
                                    {% for cercle in cercles %}
                                        <option value="{{ cercle.id }}">{{ cercle.name|upper }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <hr>
                        <!-- filterTF -->
                        <div class="form-row align-items-end mt-2 mb-2">
                            <div class="col-md-6 form-group">
                                <label for="filterTF"><u>TF</u></label>
                                <input type="text" id="filterTF" class="form-control text-center text-uppercase"
                                       placeholder="RECHERCHER PAR TF">
                            </div>
                            <!-- filterQuartier -->
                            <div class="col-md-6 form-group">
                                <label for="filterQuartier">QUARTIER</label>
                                <select name="filterQuartier" id="filterQuartier" class="form-control text-uppercase">
                                    <option value="">-- CHOISIR LE QUARTIER --</option>
                                    {% for quartier in quartiers %}
                                        <option value="{{ quartier.id }}">{{ quartier.name|upper }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <hr>
                        <div class="form-row align-items-end mt-2 mb-2">
                            <!-- numeroExpertise -->
                            <div class="col-md-6 form-group">
                                <label for="numeroExpertise"><u>EXPERTISE</u></label>
                                <input type="text" name="numeroExpertise" id="numeroExpertise" class="form-control"
                                       placeholder="NUMERO EXPERTISE">
                            </div>
                            <!-- numeroMbeyan -->
                            <div class="col-md-6 form-group">
                                <label for="numeroMbeyan"><u>MBEYAN</u></label>
                                <input type="text" name="numeroMbeyan" id="numeroMbeyan" class="form-control"
                                       placeholder="NUMERO MBEYAN">
                            </div>
                        </div>
                        <hr>
                        <div id="contentDateFInDation" class="mt-2 mb-2">
                            <p class="font-weight-bolder"><u>DATE FIN DATION</u></p>
                            <div class="form-row align-items-end">
                                <!-- dateDebutDation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateDebutDation"><u>INF</u></label>
                                    <input type="date" class="form-control" id="dateDebutDation">
                                </div>
                                <!-- dateFinDation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateFinDation"><u>SUP</u></label>
                                    <input type="date" class="form-control" id="dateFinDation">
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div id="contentDateSortiImmobilisation" class="mt-2 mb-2">
                            <p class="font-weight-bolder"><u>DATE SORTI IMMOBILISATION</u></p>
                            <div class="form-row align-items-end">
                                <!-- dateDebutImmobilisation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateDebutImmobilisation"><u>INF</u></label>
                                    <input type="date" class="form-control" id="dateDebutImmobilisation">
                                </div>
                                <!-- dateFinImmobilisation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateFinImmobilisation"><u>SUP</u></label>
                                    <input type="date" class="form-control" id="dateFinImmobilisation">
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div id="contentType" class="form-row mt-2 mb-2">
                            <!-- typeDocumentFilter -->
                            <div class="col-md-6 form-group">
                                <label for="typeDocumentFilter"><u>DOCUMENT</u></label>
                                <select name="typeDocumentFilter" class="form-control" id="typeDocumentFilter">
                                    <option value="">-- CHOISIR TYPE DOCUMENT --</option>
                                    {% for typeDocument in typeDocuments %}
                                        <option value="{{ typeDocument.id }}">-- {{ typeDocument.name|upper }}--
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <!-- typeAcquisitionFilter -->
                            <div class="col-md-6 form-group">
                                <label for="typeAcquisitionFilter"><u>ACQUISITION</u></label>
                                <select class="form-control" name="typeAcquisitionFilter[]"
                                        id="typeAcquisitionFilter" multiple="multiple">
                                    {% for typeAcquisition in typeAcquisitions %}
                                        <option value="{{ typeAcquisition.id }}">{{ typeAcquisition.name|upper }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <hr>
                        <div id="contentTypeBien" class="form-row mt-2 mb-2">
                            <!-- typeUsageBienFilter -->
                            <div class="col-md-6 form-group">
                                <label for="typeUsageBienFilter"><u>USAGE BIEN</u></label>
                                <select name="typeUsageBienFilter" class="form-control"
                                        id="typeUsageBienFilter">
                                    <option value="">-- CHOISIR TYPE USAGE --</option>
                                    {% for typeUsageBien in typeUsageBiens %}
                                        <option value="{{ typeUsageBien.id }}">-- {{ typeUsageBien.name|upper }}--
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <!-- typeBienFilter -->
                            <div class="col-md-6 form-group">
                                <label for="typeBienFilter"><u>TYPE BIEN</u></label>
                                <select name="typeBienFilter" class="form-control" id="typeBienFilter">
                                    <option value="">-- CHOISIR TYPE BIEN --</option>
                                    {% for typeBien in typeBiens %}
                                        <option value="{{ typeBien.id }}">-- {{ typeBien.name|upper }}--
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <hr>
                        <div id="contentPrixEvaluation" class="mt-2 mb-2">
                            <p><u>PRIX EVALUATION</u></p>
                            <div class="form-row align-items-end">
                                <!-- prixInf -->
                                <div class="col-md-6 form-group">
                                    <label for="prixInf"><u>INF</u></label>
                                    <input type="number" id="prixInf" class="form-control" name="prixEvaluationInf">
                                </div>
                                <!-- prixSup -->
                                <div class="col-md-6 form-group">
                                    <label for="prixSup"><u>SUP</u></label>
                                    <input type="number" id="prixSup" class="form-control" name="prixEvaluationSup">
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div id="contentDateEValuation" class="mt-2 mb-2">
                            <p><u>DATE DERNIERE EVALUATION</u></p>
                            <div class="form-row align-items-end">
                                <!-- dateInfLastEvaluation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateInfLastEvaluation"><u>INF</u></label>
                                    <input type="date" class="form-control" id="dateInfLastEvaluation">
                                </div>
                                <!-- dateSupLastEvaluation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateSupLastEvaluation"><u>SUP</u></label>
                                    <input type="date" class="form-control" id="dateSupLastEvaluation">
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div id="contentDateEValuation" class="mt-2 mb-2">
                            <p><u>DATE PROCHAINE EVALUATION</u></p>
                            <div class="form-row align-items-end">
                                <!-- dateInfNextEvaluation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateInfNextEvaluation"><u>INF</u></label>
                                    <input type="date" class="form-control" id="dateInfNextEvaluation">
                                </div>
                                <!-- dateSupNextEvaluation -->
                                <div class="col-md-6 form-group">
                                    <label for="dateSupNextEvaluation"><u>SUP</u></label>
                                    <input type="date" class="form-control" id="dateSupNextEvaluation">
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div class="text-center btn-group" role="group">
                            <button id="btnReset" type="button" class="btn btn-warning text-uppercase">Reinitialiser
                            </button>
                            <button id="btnSend" type="button" class="btn btn-primary">APPLIQUER</button>
                            <button type="button" class="btn btn-danger text-uppercase" data-dismiss="modal">Fermer
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {# TABLE EXPORT DES DONNEES #}
    <div class="table-responsive d-none">
        <table id="tableExport" style="white-space: nowrap"
               class="table diplay table-hover table-bordered text-center font-weight-bold text-uppercase">
            <thead>
            <tr class="bg-gradient-dark text-white">

                <th>N° EXPERTISE</th>

                <th>N° DOCUMENT</th>

                <th>N° MBEYAN</th>

                <th>QUARTIER</th>

                <th>CERCLE</th>

                <th>REGION</th>

                <th>PRIX EXPERTISE</th>

                <th>CLIENT</th>

                <th>PROPRIETAIRE</th>

                <th>SUR LE DOCUMENT</th>

                <th>TYPE ACQUISITION</th>

                <th>DOCUMENT PROPRIETE</th>

                <th>TYPE BIEN</th>

                <th>TYPE USAGE</th>

                <th>SUPERFICIE</th>

                <th>LATITUDE</th>

                <th>LONGITUDE</th>

                <th>DATE DERNIERE EVALUATION</th>

                <th>DATE PROCHAINE EVALUATION</th>

                <th>DATE ENTREE</th>

                <th>DATE SORTIE IMMOBILISATION</th>

                <th>DATE FIN DATION</th>

                <th>ENREGISTRE LE</th>

                <th>ENREGISTRE PAR</th>
            </tr>
            </thead>
            <tbody>

            </tbody>
        </table>
    </div>
{% endblock %}
{% block javascripts %}
    <link rel="stylesheet" type="text/css" href="https://unpkg.com/slick-loader@1.1.20/slick-loader.min.css">
    <script src="https://unpkg.com/slick-loader@1.1.20/slick-loader.min.js"></script>
    <script src="//cdn.rawgit.com/rainabba/jquery-table2excel/1.1.0/dist/jquery.table2excel.min.js"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('#typeAcquisitionFilter').multiselect({
                templates: {
                    li: '<a class"multiselect-option dropdown-item"><a><label style="display:inline;"></label><input type="text" /></a></a>'
                }
            });
        });
    </script>
    <script>
        let expertiseRow = $('#expertiseSort');
        let tfRow = $('#tfSort');
        let quartierRow = $('#quartierSort');
        let numeroMbeyanRow = $('#numeroMbeyanSort');
        let cercleRow = $('#cercleSort');
        let regionRow = $('#regionSort');
        let prixRow = $('#prixSort');
        let clientRow = $('#clientSort');
        let proprietaireRow = $('#proprietaireSort');
        let nomSurLeDocumentRow = $('#nomSurLeDocumentSort');
        let typeAcquisitionRow = $('#typeAcquisitionSort');
        let documentRow = $('#documentSort');
        let bienRow = $('#bienSort');
        let usageRow = $('#usageSort');
        let superficieRow = $('#superficieSort');
        let lastExpertiseRow = $('#lastExpertiseSort');
        let nextExpertiseRow = $('#nextExpertiseSort');
        let createdAtRow = $('#createdAtSort');
        let updatedAtRow = $('#updatedAtSort');
        let createdByRow = $('#createdBySort');
        let type = '';
        let isAsc = true;
        let allDatas = {};
        let sortBy = '';
        let sortType = '';

        // PARTIE 2
        let nbBien = 0;
        let checked = false;
        let btnCOCHER = $('#checkAll');
        let btnDECOCHER = $('#inCheckAll');
        let btnEXPORT = $('#btnEXPORTER');
        let typeClientFilter = $('#filtreTypeClient');
        let clientFilter = $('#clientFilter');
        let clientStructure = $('#clientStructure');
        let tfFilter = $('#filterTF');
        let quartierFilter = $('#filterQuartier');
        let regionFilter = $('#filterRegion');
        let cercleFilter = $('#filterCercle');
        let numeroExpertiseFilter = $('#numeroExpertise');
        let numeroMbeyanFilter = $('#numeroMbeyan');
        let dateDebutDation = $('#dateDebutDation');
        let dateFinDation = $('#dateFinDation');
        let dateDebutImmobilisation = $('#dateDebutImmobilisation');
        let dateFinImmobilisation = $('#dateFinImmobilisation');
        let typeDocumentFilter = $('#typeDocumentFilter');
        let typeUsageBienFilter = $('#typeUsageBienFilter');
        let typeBienFilter = $('#typeBienFilter');
        let prixEstimationFilterInf = $('#prixInf');
        let prixEstimationFilterSup = $('#prixSup');
        let dateEvaluationInfFilter = $('#dateInfLastEvaluation');
        let dateEvaluationSupFilter = $('#dateSupLastEvaluation');
        let dateNextEvaluationInfFilter = $('#dateInfNextEvaluation')
        let dateNextEvaluationSupFilter = $('#dateSupNextEvaluation');
        btnSend = $('#btnSend');
        let btnReset = $('#btnReset');
        let isValidatedForm = false;

        // CHARGEMENT DE LA PAGE
        $(document).ready(function () {
            getAllExpertise();
        });

        // RECCUPERATIONS DES EXPERTISES
        function getAllExpertise() {
            $.ajax({
                url: '/get-all-expertises',
                type: 'GET',
                success: function (datas) {
                    allDatas = datas;
                    nbBien = allDatas.length;
                    sortBy = 'expertise';
                    sortType = 'DESC';
                    putDataInTable(allDatas);
                },
                error: function (errors) {
                    console.log('error => ' + errors);
                }
            });
        }

        // TRI PAR EXPERTISE
        expertiseRow.on('click', function () {
            if (isAsc) {
                sortIconDisplay('expertise', true);
                sortAllDatas(allDatas, 'expertise', true);
