                dataSumitted.regionFilter = regionFilterValue;
                isEmpty = false;
            }

            if (cercleFilterValue !== '') {
                dataSumitted.cercleFilter = cercleFilterValue;
                isEmpty = false;
            }

            if (numeroExpertiseValue !== '') {
                dataSumitted.numeroExpertise = numeroExpertiseValue;
                isEmpty = false;
            }
            if (numeroMbeyanValue !== '') {
                dataSumitted.numeroMbeyan = numeroMbeyanValue;
                isEmpty = false;
            }
            if ((dateDebutDationValue === '' && dateFinDationValue !== '') || (dateDebutDationValue !== '' && dateFinDationValue === '') || (dateDebutDationValue > dateFinDationValue)) {
                document.getElementById('dateFinDation').classList.add('is-invalid');
                document.getElementById('dateDebutDation').classList.add('is-invalid');
                isValidated = false;
                dateError = true;
                alert('error dation');
            } else {
                if (dateDebutDationValue !== '' && dateFinDationValue !== '') {
                    dataSumitted.dateFinDation = dateFinDationValue;
                    dataSumitted.dateDebutDation = dateDebutDationValue;
                    isEmpty = false;
                }
            }
            if ((dateDebutImmobilisationValue !== '' && dateFinImmobilisationValue === '') || (dateDebutImmobilisationValue === '' && dateFinImmobilisationValue !== '') || (dateDebutImmobilisationValue > dateFinImmobilisationValue)) {
                document.getElementById('dateDebutImmobilisation').classList.add('is-invalid');
                document.getElementById('dateFinImmobilisation').classList.add('is-invalid');
                dateError = true;
                isValidated = false;
            } else {
                if (dateDebutImmobilisationValue !== '' && dateFinImmobilisationValue !== '') {
                    dataSumitted.dateFinImmobilisation = dateFinImmobilisationValue;
                    dataSumitted.dateDebutImmobilisation = dateDebutImmobilisationValue;
                    isEmpty = false;
                }
            }
            if (typeDocumentFilterValue !== '') {
                dataSumitted.typeDocument = typeDocumentFilterValue;
                isEmpty = false;
            }
            let typeAcquisitionValues = $('#typeAcquisitionFilter').val();
            if (typeAcquisitionValues !== [""] && typeAcquisitionValues.length !== 0) {
                dataSumitted.typeAcquisition = typeAcquisitionValues;
                isEmpty = false;
            }
            if (typeUsageBienValue !== '') {
                dataSumitted.typeUsageBien = +typeUsageBienValue;
                isEmpty = false;
            }
            if (typeBienValue !== '') {
                dataSumitted.typeBien = +typeBienValue;
                isEmpty = false;
            }
            if ((prixEstimationInfValue !== '' && prixEstimationSupValue === '') || (prixEstimationInfValue === '' && prixEstimationSupValue !== '') || (prixEstimationInfValue > prixEstimationSupValue) || (prixEstimationInfValue < 0 || prixEstimationSupValue < 0)) {
                document.getElementById('prixInf').classList.add('is-invalid');
                document.getElementById('prixSup').classList.add('is-invalid');
                errorPrixEstimation = true;
                isValidated = false;
                alert('error estiamation');
            } else {
                if (prixEstimationSupValue !== '' && prixEstimationInfValue !== '') {
                    dataSumitted.prixEstimationInf = +prixEstimationInfValue;
                    dataSumitted.prixEstimationSup = +prixEstimationSupValue;
                    isEmpty = false;
                }
            }
            if ((dateInfLastEvaluationValue !== '' && dateSupLastEvaluationValue === '') || (dateInfLastEvaluationValue === '' && dateSupLastEvaluationValue !== '') || (dateInfLastEvaluationValue > dateSupLastEvaluationValue)) {
                document.getElementById('dateInfLastEvaluation').classList.add('is-invalid');
                document.getElementById('dateSupLastEvaluation').classList.add('is-invalid');
                dateError = true;
                isValidated = false;
            } else {
                if (dateInfLastEvaluationValue !== '' && dateSupLastEvaluationValue !== '') {
                    dataSumitted.dateInfLastEvaluation = dateInfLastEvaluationValue;
                    dataSumitted.dateSupLastEvaluation = dateSupLastEvaluationValue;
                    isEmpty = false;
                }
            }
            if ((dateInfNextEvaluationValue !== '' && dateSupNextEvaluationValue === '') || (dateInfNextEvaluationValue === '' && dateSupNextEvaluationValue !== '') || (dateInfNextEvaluationValue > dateSupNextEvaluationValue)) {
                document.getElementById('dateInfNextEvaluation').classList.add('is-invalid');
                document.getElementById('dateSupNextEvaluation').classList.add('is-invalid');
                dateError = true;
                isValidated = false;
            } else {
                if (dateInfNextEvaluationValue !== '' && dateSupNextEvaluationValue !== '') {
                    dataSumitted.dateInfNextEvaluation = dateInfNextEvaluationValue;
                    dataSumitted.dateSupNextEvaluation = dateSupNextEvaluationValue;
                    isEmpty = false;
                }
            }
            if (errorPrixEstimation) {
                alert('Verifiez les prix evalutions');
            }
            if (dateError) {
                alert('verifiez date inf et sup');
            }
            if (isValidated && isEmpty === false) {
                document.getElementById('dateDebutImmobilisation').classList.remove('is-invalid');
                document.getElementById('dateFinImmobilisation').classList.remove('is-invalid');
                document.getElementById('dateDebutImmobilisation').classList.remove('is-invalid');
                document.getElementById('dateFinImmobilisation').classList.remove('is-invalid');
                document.getElementById('dateInfNextEvaluation').classList.remove('is-invalid');
                document.getElementById('dateSupNextEvaluation').classList.remove('is-invalid');
                document.getElementById('dateInfLastEvaluation').classList.remove('is-invalid');
                document.getElementById('dateSupLastEvaluation').classList.remove('is-invalid');
                document.getElementById('prixInf').classList.remove('is-invalid');
                document.getElementById('prixSup').classList.remove('is-invalid');
                if (dataSumitted !== []) {
                    getData(dataSumitted);
                }

                $('#exampleModalCenter').modal('hide');
            }
        });

        // RECCUPERATION DES DONNEES DU FILTRE
        function getData(critere) {
            $.ajax({
                url: '/koh-archivage/get-expertises-by-critere',
                dataType: 'JSON',
                type: 'POST',
                data: critere,
                success: function (data) {
                    allDatas = data;
                    nbBien = allDatas.length;
                    sortBy = 'expertise';
                    sortType = 'DESC';
                    putDataInTable(allDatas);
                },
                error: function (error) {
                    alert('error => ' + JSON.stringify(error));
                    console.log('error ==> ' + error);
                }
            })
        }

        // RECCUPERATION DES TYPES ACQUISITIONS
        function loadTypeAcquisition() {
            $('#typeAcquisitionFilter').empty();
            $.ajax({
                url: '/koh_archivage/admin/type_acquisitions/get_type_acquisition',
                type: 'get',
                success: function (data) {
                    $.each(data, function (index, type) {
                        $('#filterQuartier').append($('<option>', {
                            value: type['id'],
                            text: type['libelle'].toUpperCase()
                        }));
                    });
                },
                error: function (error) {
                    console.log('error ==> ' + error);
                }
            });
        }
    </script>
{% endblock %}