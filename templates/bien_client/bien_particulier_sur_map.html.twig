        function getFormattedDate(date) {
            let year = date.getFullYear();
            let month = (1 + date.getMonth()).toString().padStart(2, '0');
            let day = date.getDate().toString().padStart(2, '0');

            return day + '/' + month + '/' + year;
        }

        function changementEtatAlert(alertType, show) {
            if (alertType === 'all') {
                if (show) {
                    document.getElementById('allDataAlert').classList.remove('d-none');
                } else {
                    document.getElementById('allDataAlert').classList.add('d-none');
                }
            }

            if (alertType === 'success') {
                if (show) {
                    document.getElementById('successAlert').classList.remove('d-none');
                } else {
                    document.getElementById('successAlert').classList.add('d-none');
                }
            }

            if (alertType === 'danger') {
                if (show) {
                    document.getElementById('dangerAlert').classList.remove('d-none');
                } else {
                    document.getElementById('dangerAlert').classList.add('d-none');
                }
            }
        }

