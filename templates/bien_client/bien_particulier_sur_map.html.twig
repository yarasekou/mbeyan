        btnTotal.on('click', function () {
            let isCheck = false;
            let total = 0;
            let data = [];
            for (let i = 0; i < allDatas.length; i++) {
                if ($('#check' + allDatas[i].expertiseId).prop('checked') === true) {
                    isCheck = true;
                    let id = $('#check' + allDatas[i].expertiseId).val();
                    data.push(id);
                } else {
                    console.log('not checked ' + '#check' + allDatas[i].expertiseId);
                }
            }
            console.log('data == ' + data.toString());
            $.ajax({
                url: "/koh-archivage/biens-by-array/" + data.toString() + '/order/region/type/ASC',
                type: 'get',
                datatype: 'json',
                success: function (datas) {
                    for (let i = 0; i < datas.length; i++) {
                        let data = datas[i];
                        total = (total + parseFloat(data.prix_derniere_evaluation));
