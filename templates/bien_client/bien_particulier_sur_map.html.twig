        function getData(critere) {
            document.getElementById('total_montant').classList.add('d-none');
            for (let i = 1; i <= nbreBien; i++) {
                $('#list-biens #list-item' + i).remove();
            }
            $.ajax({
                url: '/koh-archivage/get-biens-particulier-by-critere-and-user',
                dataType: 'JSON',
                type: 'POST',
                data: critere,
                success: function (data) {
                    allDatas = data;
                    if (data.length >= 2) {
                        document.getElementById('COCHER').classList.remove('d-none');
                    } else {
                        document.getElementById('COCHER').classList.add('d-none');
                    }
                    if (data.length >= 1) {
                        document.getElementById('btn-total').classList.remove('d-none');
                        document.getElementById('btn-export').classList.remove('d-none');
                        changementEtatAlert('success', true);
                        window.setTimeout(function () {
                            changementEtatAlert('success', false);
                        }, 5000);
                    } else {
                        changementEtatAlert('danger', true);
                        document.getElementById('btn-total').classList.add('d-none');
                        document.getElementById('btn-export').classList.add('d-none');

                        window.setTimeout(function () {
                            changementEtatAlert('danger', false);
                        }, 5000);
                    }
                    initMap(data, true);
                },
                error: function (error) {
                    alert('error => ' + JSON.stringify(error));
                }
            })
        }

