{{ form_start(form) }}
<div class="form-row align-items-end">
    <div class="col-md-6">
        {{ form_row(form.firstName) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.lastName) }}
    </div>
</div>
<div class="form-row align-items-end">
    <div class="col-md-6">
        {{ form_row(form.email) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.nomUtilisateur) }}
    </div>
</div>

<div class="form-row align-items-end">
    <div class="col-md-6">
        {{ form_row(form.telephone) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.adresse) }}
    </div>
</div>

<div class="form-row align-items-end">
    <div class="col-md-6">
        {{ form_row(form.password.first) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.password.second) }}
    </div>
</div>

{% if app.user.isKohUser and app.user.isAdmin and app.request.attributes.get('_route') != 'koh_utilisateur_edit' %}
    <div id="koh_utilisateur">
        <div class="form-group">
            <div class="form-check">
                <input type="checkbox" id="koh_utilisateur_isAdmin" name="isAdmin"
                                           class="form-check-input" value="1"/>
                <label class="form-check-label" for="koh_utilisateur_isAdmin">Est administrateur de
                    l&#039;application</label></div>
        </div>
    </div>
{% endif %}

    {{ form_widget(form) }}

<button class="btn btn-dark float-right">{{ button_label|default('ENREGISTRER') }}</button>
{{ form_end(form) }}
